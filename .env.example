# 백엔드 REST API 서버 주소
VITE_API_BASE_URL=http://localhost:4000

# Socket.IO 웹소켓 서버 주소 (일반적으로 REST API와 동일)
VITE_WS_URL=http://localhost:4000

# 카카오맵 JavaScript 앱 키
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 미설정 시 MapPage에 안내 UI가 표시됩니다 (다른 기능은 정상 동작)
VITE_APP_KAKAO_JS_KEY=your_kakao_javascript_key

# 카카오 소셜 로그인 (OAuth)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
# 리다이렉트 URI 등록: 카카오 개발자 콘솔 → 플랫폼 → Web → 사이트 도메인 + 리다이렉트 URI
VITE_APP_REST_API_KEY=your_kakao_rest_api_key
VITE_APP_REDIRECT_URL=http://localhost:5173/auth/kakao

# 네이버 소셜 로그인 (OAuth)
# 발급: https://developers.naver.com → Application → 애플리케이션 등록
# 서비스 환경: WEB / 로그인 오픈 API 서비스 선택 → 이메일, 별명, 프로필 사진
# 콜백 URL 등록: http://localhost:5173/auth/naver
VITE_APP_NAVER_CLIENT_ID=your_naver_client_id
VITE_APP_NAVER_REDIRECT_URL=http://localhost:5173/auth/naver

# 구글 소셜 로그인 (OAuth 2.0 PKCE)
# 발급: https://console.cloud.google.com
#   → APIs & Services → Credentials → 사용자 인증 정보 만들기 → OAuth 클라이언트 ID
#   → 애플리케이션 유형: 웹 애플리케이션
#   → 승인된 리디렉션 URI: http://localhost:5173/auth/google  (+ 배포 도메인)
# ⚠ client_secret 은 .env 에 넣지 마세요 — PKCE 방식이라 불필요합니다
VITE_APP_GOOGLE_CLIENT_ID=your_google_client_id
VITE_APP_GOOGLE_REDIRECT_URL=http://localhost:5173/auth/google
